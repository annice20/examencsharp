@model List<examencsharp.Models.Candidat>
@{
    ViewData["Title"] = "Voter";
    var election = ViewBag.Election as examencsharp.Models.Election;
}

<div class="p-3 mb-4 text-white rounded"
     style="background:linear-gradient(135deg,#0f1114,#1a1a2e)">
    <span class="badge bg-danger mb-2">● Vote en cours</span>
    <h3 class="fw-bold mb-1">@election?.TitreElection</h3>
    <small class="text-white-50">
         @election?.DateElection.ToString("dd/MM/yyyy")
        &nbsp;|&nbsp;
        Fokontany @election?.Fokontany?.NomFokontany
    </small>
</div>

<form asp-action="Voter" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="electionId" value="@election?.Id"/>
    <div class="row g-3 mb-4">
        @foreach (var c in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 border-2 candidate-card"
                     style="cursor:pointer" onclick="selectCandidat(@c.Id, this)">
                    <div class="card-body text-center p-4">
                        <div style="font-size:4rem;margin-bottom:12px">👤</div>
                        <h5 class="fw-bold">@c.NomCandidat @c.PrenomCandidat</h5>
                        <p class="text-muted small">@c.Programme</p>
                        <input class="form-check-input" type="radio"
                               name="candidatId" id="cand_@c.Id"
                               value="@c.Id" required style="display:none"/>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-success btn-lg px-5"
                id="btnVoter" disabled>
            Confirmer mon vote
        </button>
    </div>
</form>

@section Scripts {
<script>
function selectCandidat(id, el) {
    document.querySelectorAll('.candidate-card').forEach(c => {
        c.classList.remove('border-success');
        c.style.boxShadow = '';
    });
    el.classList.add('border-success');
    el.style.boxShadow = '0 0 0 4px rgba(26,122,74,0.15)';
    document.getElementById('cand_' + id).checked = true;
    document.getElementById('btnVoter').disabled = false;
}
</script>
}