@{
    ViewData["Title"] = "Déjà Voté";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <i class="fas fa-check-double text-success" style="font-size: 80px;"></i>
                    <h3 class="mt-3 text-success">Vous avez déjà voté !</h3>
                    <p class="text-muted mt-2">
                        Vous avez déjà participé à cette élection.<br/>
                        Un seul vote est autorisé par élection.
                    </p>
                    <a href="/Dashboard" class="btn btn-primary mt-3">
                        <i class="fas fa-home me-2"></i>Retour au Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>