@{ ViewData["Title"] = "Vote confirmé"; }

<div class="text-center py-5">
    <div style="font-size:4rem">confirmé</div>
    <h2 class="fw-bold text-success mt-3">Vote enregistré !</h2>
    <p class="text-muted">Votre vote a été enregistré de façon sécurisée.</p>
    <div class="card mx-auto mt-4 border-success" style="max-width:420px">
        <div class="card-body">
            <small class="text-muted text-uppercase fw-bold">Votre code QR de confirmation</small>
            <div class="bg-light rounded p-2 mt-2 font-monospace small text-break">
                @ViewBag.QRCode
            </div>
        </div>
    </div>
    <a asp-controller="Home" asp-action="Index"
       class="btn btn-outline-secondary mt-4">← Retour à l'accueil</a>
</div>