@{
    ViewData["Title"] = "Non Éligible";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <i class="fas fa-times-circle text-danger" style="font-size: 80px;"></i>
                    <h3 class="mt-3 text-danger">Non Éligible</h3>
                    <p class="text-muted mt-2">
                        Vous n'êtes pas éligible pour voter.<br/>
                        Vous devez être enregistré comme citoyen avec une CIN valide.
                    </p>
                    <a href="/Dashboard" class="btn btn-primary mt-3">
                        <i class="fas fa-home me-2"></i>Retour au Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>