@{
    ViewData["Title"] = "Nouvelle Élection";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Nouvelle Élection</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Titre de l'élection</label>
                            <input type="text" name="TitreElection" class="form-control"
                                   placeholder="Ex: Election Fokontany 2025" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Date de l'élection</label>
                            <input type="datetime-local" name="DateElection"
                                   class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Fokontany</label>
                            <select name="FokontanyId" class="form-select" required>
                                <option value="">-- Choisir un Fokontany --</option>
                                @foreach (var f in ViewBag.Fokontanys)
                                {
                                    <option value="@f.Id">@f.NomFokontany</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox"
                                       name="IsActive" value="true" id="isActive" />
                                <label class="form-check-label fw-semibold" for="isActive">
                                    Activer immédiatement
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Créer l'élection
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>