@model List<examencsharp.Models.Candidat>
@{
    ViewData["Title"] = "Résultats";
    var election = ViewBag.Election as examencsharp.Models.Election;
    var resultats = ViewBag.Resultats as List<dynamic>;
    int totalVotes = 0;
    if (resultats != null)
    {
        foreach (var r in resultats) totalVotes += (int)r.Total;
    }
}

<div class="container mt-4">
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-bar-chart"></i> Résultats — @election?.TitreElection</h4>
            <span class="badge bg-light text-dark fs-6">@totalVotes votes au total</span>
        </div>
        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-info">Aucun candidat pour cette élection.</div>
            }
            else
            {
                <div class="row">
                    @foreach (var candidat in Model)
                    {
                        int votes = 0;
                        if (resultats != null)
                        {
                            foreach (var r in resultats)
                            {
                                if ((int)r.CandidatId == candidat.Id)
                                {
                                    votes = (int)r.Total;
                                    break;
                                }
                            }
                        }
                        double pct = totalVotes > 0 ? Math.Round((double)votes / totalVotes * 100, 1) : 0;

                        <div class="col-md-6 mb-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h5 class="mb-0">@candidat.NomCandidat @candidat.PrenomCandidat</h5>
                                        <span class="badge bg-primary fs-6">@votes votes</span>
                                    </div>
                                    <div class="progress" style="height: 25px;">
                                        <div class="progress-bar bg-success" role="progressbar"
                                             style="width: @pct%"
                                             aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                            @pct%
                                        </div>
                                    </div>
                                    <small class="text-muted">@pct% des votes</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                int maxVotes = 0;
                examencsharp.Models.Candidat? gagnant = null;
                if (resultats != null)
                {
                    foreach (var r in resultats)
                    {
                        if ((int)r.Total > maxVotes)
                        {
                            maxVotes = (int)r.Total;
                            foreach (var c in Model)
                            {
                                if (c.Id == (int)r.CandidatId)
                                {
                                    gagnant = c;
                                    break;
                                }
                            }
                        }
                    }
                }

                if (gagnant != null)
                {
                    <div class="alert alert-success mt-3 text-center fs-5">
                        🏆 <strong>Gagnant : @gagnant.NomCandidat @gagnant.PrenomCandidat</strong>
                        avec @maxVotes votes
                    </div>
                }
            }

            <a asp-action="Index" class="btn btn-secondary mt-3">
                <i class="bi bi-arrow-left"></i> Retour aux élections
            </a>
        </div>
    </div>
</div>