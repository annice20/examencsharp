@model List<examencsharp.Models.Election>
@{ ViewData["Title"] = "Élections"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">📋 Gestion des <span style="color:#C0392B">Élections</span></h4>
    <a asp-action="Create" class="btn btn-danger">+ Nouvelle élection</a>
</div>

<div class="row g-3">
    @foreach (var e in Model)
    {
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="fw-bold mb-0">@e.TitreElection</h5>
                        @if (e.IsActive)
                        { <span class="badge bg-success">● Actif</span> }
                        else
                        { <span class="badge bg-secondary">Inactif</span> }
                    </div>
                    <p class="text-muted small mb-3">
                        📍 @e.Fokontany?.NomFokontany
                        &nbsp;|&nbsp;
                        📅 @e.DateElection.ToString("dd/MM/yyyy")
                    </p>
                    <div class="d-flex gap-2">
                        <form asp-action="ToggleActive" asp-route-id="@e.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm @(e.IsActive ? "btn-warning" : "btn-success")">
                                @(e.IsActive ? "⏸ Désactiver" : "▶ Activer")
                            </button>
                        </form>
                        <a asp-action="Resultats" asp-route-id="@e.Id"
                           class="btn btn-sm btn-outline-primary">📊 Résultats</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>