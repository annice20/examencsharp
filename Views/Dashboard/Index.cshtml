@model examencsharp.Models.Views.VDashboard
@{ ViewData["Title"] = "Dashboard"; }

<style>
    body{
        background: linear-gradient(135deg,#4f46e5,#bda8d1);
    }

    body, .dashboard-root {
        font-family: 'DM Sans', sans-serif;
    }

    .dashboard-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.9rem;
        letter-spacing: -0.5px;
    }

    .stat-card {
        border-radius: 16px !important;
        border: 1px solid rgba(0,0,0,0.06) !important;
        background: #fff;
        transition: transform .18s ease, box-shadow .18s ease;
        overflow: hidden;
        position: relative;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.10) !important;
    }

    .stat-card .card-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        border-radius: 16px 16px 0 0;
    }

    .accent-blue   { background: linear-gradient(90deg, #3B82F6, #60A5FA); }
    .accent-indigo { background: linear-gradient(90deg, #6366F1, #A5B4FC); }
    .accent-amber  { background: linear-gradient(90deg, #F59E0B, #FCD34D); }
    .accent-green  { background: linear-gradient(90deg, #10B981, #6EE7B7); }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto 10px;
    }

    .icon-blue   { background: #EFF6FF; }
    .icon-indigo { background: #EEF2FF; }
    .icon-amber  { background: #FFFBEB; }
    .icon-green  { background: #ECFDF5; }

    .stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        color: #111827;
    }

    .stat-label {
        font-size: .78rem;
        color: #6B7280;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-top: 4px;
    }

    .results-card {
        border-radius: 16px !important;
        border: 1px solid rgba(0,0,0,0.06) !important;
        overflow: hidden;
    }

    .results-card .card-header {
        background: linear-gradient(135deg, #1E293B 0%, #334155 100%) !important;
        color: #fff !important;
        padding: 18px 24px;
        border-bottom: none;
    }

    .results-card .card-header .badge-election {
        background: rgba(255,255,255,0.15);
        color: #fff;
        font-size: .72rem;
        padding: 4px 10px;
        border-radius: 999px;
        font-weight: 500;
        letter-spacing: .3px;
    }

    .candidate-row {
        padding: 14px 0;
        border-bottom: 1px solid #F3F4F6;
    }

    .candidate-row:last-child { border-bottom: none; }

    .candidate-name {
        font-weight: 600;
        color: #111827;
        font-size: .95rem;
    }

    .vote-count {
        font-size: .82rem;
        color: #6B7280;
    }

    .pct-badge {
        font-family: 'Syne', sans-serif;
        font-size: .85rem;
        font-weight: 700;
        color: #C0392B;
        min-width: 44px;
        text-align: right;
    }

    .progress {
        border-radius: 999px;
        background: #F3F4F6;
    }

    .progress-bar {
        background: linear-gradient(90deg, #C0392B, #E74C3C) !important;
        border-radius: 999px;
        transition: width .6s cubic-bezier(.4,0,.2,1);
    }

    .date-chip {
        background: #F1F5F9;
        color: #64748B;
        border-radius: 999px;
        padding: 5px 14px;
        font-size: .78rem;
        font-weight: 500;
    }
</style>

<div class="dashboard-root mt-5 pt-5 px-4 mx-auto">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="dashboard-title fw-bold mb-0">
            Tableau de bord <span style="color:#C0392B">Admin</span>
        </h2>
        <span class="date-chip">📅 @DateTime.Now.ToString("dd/MM/yyyy")</span>
    </div>

    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card border-0 shadow-sm text-center p-4">
                <div class="card-accent accent-blue"></div>
                <div class="stat-icon icon-blue">👥</div>
                <div class="stat-value">@Model.total_citoyens</div>
                <div class="stat-label">Total citoyens</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card border-0 shadow-sm text-center p-4">
                <div class="card-accent accent-indigo"></div>
                <div class="stat-icon icon-indigo">🪪</div>
                <div class="stat-value">@Model.cin_delivered</div>
                <div class="stat-label">CIN approuvées</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card border-0 shadow-sm text-center p-4">
                <div class="card-accent accent-amber"></div>
                <div class="stat-icon icon-amber">⏳</div>
                <div class="stat-value text-warning">@Model.pending_requests</div>
                <div class="stat-label">En attente</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card border-0 shadow-sm text-center p-4">
                <div class="card-accent accent-green"></div>
                <div class="stat-icon icon-green">🗳️</div>
                <div class="stat-value text-success">@Model.total_votes</div>
                <div class="stat-label">Votes enregistrés</div>
            </div>
        </div>
    </div>

    <!-- Election Results -->
    @if (ViewBag.Resultats != null)
    {
        <div class="card results-card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <span style="font-size:1.1rem">🗳️</span>
                    <span class="fw-bold" style="font-family:'Syne',sans-serif;font-size:1rem;">
                        Résultats des votes
                    </span>
                </div>
                <span class="badge-election">@ViewBag.ElectionTitre</span>
            </div>
            <div class="card-body px-4 py-3">
                @{ var total = ((List<examencsharp.Models.Views.VResult>)ViewBag.Resultats).Sum(r => r.total_votes); }
                @foreach (var r in (List<examencsharp.Models.Views.VResult>)ViewBag.Resultats)
                {
                    var pct = total > 0 ? Math.Round((double)r.total_votes / total * 100, 1) : 0;
                    <div class="candidate-row">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="candidate-name">@r.NomCandidat @r.PrenomCandidat</span>
                            <div class="d-flex align-items-center gap-3">
                                <span class="vote-count">@r.total_votes votes</span>
                                <span class="pct-badge">@pct%</span>
                            </div>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar bg-danger" style="width:@pct%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>