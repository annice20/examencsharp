@model examencsharp.Models.Views.VDashboard
@{ ViewData["Title"] = "Dashboard"; }

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes countUp {
        from { opacity: 0; transform: scale(0.5); }
        to   { opacity: 1; transform: scale(1); }
    }
    @@keyframes slideInLeft {
        from { opacity: 0; transform: translateX(-30px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50%       { transform: scale(1.05); }
    }

    .dashboard-header {
        animation: slideInLeft 0.6s ease forwards;
    }
    .stat-card {
        border-radius: 16px !important;
        border: none !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        opacity: 0;
        animation: fadeInUp 0.5s ease forwards;
        overflow: hidden;
    }
    .stat-card:hover {
        transform: translateY(-6px) !important;
        box-shadow: 0 16px 40px rgba(0,0,0,0.12) !important;
    }
    .stat-card:nth-child(1) { animation-delay: 0.1s; }
    .stat-card:nth-child(2) { animation-delay: 0.2s; }
    .stat-card:nth-child(3) { animation-delay: 0.3s; }
    .stat-card:nth-child(4) { animation-delay: 0.4s; }

    .stat-value {
        animation: countUp 0.6s ease forwards;
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1;
    }
    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        animation: pulse 2s ease infinite;
    }
    .stat-border-left {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 5px;
        border-radius: 16px 0 0 16px;
    }

    .results-card {
        border-radius: 16px !important;
        border: none !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        opacity: 0;
        animation: fadeInUp 0.6s ease 0.5s forwards;
    }
    .progress-bar-animated {
        animation: progressFill 1.2s ease forwards;
    }
    @@keyframes progressFill {
        from { width: 0% !important; }
    }
    .candidate-row {
        padding: 14px 0;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.2s;
        border-radius: 10px;
        padding-left: 10px;
    }
    .candidate-row:hover { background: #f8fafc; }
    .candidate-row:last-child { border-bottom: none; }
</style>

<div class="container py-4">

    <!-- Header -->
    <div class="dashboard-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color:#1e293b; font-size:1.8rem;">
                <i class="fas fa-chart-pie me-2" style="color:#3b82f6;"></i>
                Tableau de bord
            </h2>
            <p class="text-muted mb-0" style="font-size:0.9rem;">
                Vue d'ensemble du système de vote
            </p>
        </div>
        <span class="badge rounded-pill px-3 py-2"
              style="background:#eff6ff; color:#1e40af; font-size:0.85rem; font-weight:600;">
            <i class="fas fa-calendar me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy")
        </span>
    </div>

    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#3b82f6;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2"
                           style="font-size:0.75rem; text-transform:uppercase;
                                  letter-spacing:0.8px; font-weight:600;">
                            Total Citoyens
                        </p>
                        <div class="stat-value" style="color:#1e293b;">
                            @Model.total_citoyens
                        </div>
                    </div>
                    <div class="stat-icon" style="background:#eff6ff;">
                        <i class="fas fa-users" style="color:#3b82f6;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#6366f1;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2"
                           style="font-size:0.75rem; text-transform:uppercase;
                                  letter-spacing:0.8px; font-weight:600;">
                            CIN Approuvées
                        </p>
                        <div class="stat-value" style="color:#1e293b;">
                            @Model.cin_delivered
                        </div>
                    </div>
                    <div class="stat-icon" style="background:#eef2ff;">
                        <i class="fas fa-id-card" style="color:#6366f1;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#f59e0b;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2"
                           style="font-size:0.75rem; text-transform:uppercase;
                                  letter-spacing:0.8px; font-weight:600;">
                            En Attente
                        </p>
                        <div class="stat-value" style="color:#f59e0b;">
                            @Model.pending_requests
                        </div>
                    </div>
                    <div class="stat-icon" style="background:#fffbeb;">
                        <i class="fas fa-clock" style="color:#f59e0b;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#10b981;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2"
                           style="font-size:0.75rem; text-transform:uppercase;
                                  letter-spacing:0.8px; font-weight:600;">
                            Votes Enregistrés
                        </p>
                        <div class="stat-value" style="color:#10b981;">
                            @Model.total_votes
                        </div>
                    </div>
                    <div class="stat-icon" style="background:#ecfdf5;">
                        <i class="fas fa-vote-yea" style="color:#10b981;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Résultats élection -->
    @if (ViewBag.Resultats != null)
    {
        <div class="card results-card">
            <div class="card-header border-0 d-flex justify-content-between align-items-center p-4"
                 style="background:linear-gradient(135deg,#1e40af,#3b82f6);
                        border-radius:16px 16px 0 0;">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-bar-chart text-white" style="font-size:1.1rem;"></i>
                    <span class="fw-bold text-white">Résultats des votes</span>
                </div>
                <span class="badge px-3 py-2"
                      style="background:rgba(255,255,255,0.2); color:white;
                             border-radius:999px; font-size:0.8rem;">
                    @ViewBag.ElectionTitre
                </span>
            </div>
            <div class="card-body p-4">
                @{
                    var resultats = (List<examencsharp.Models.Views.VResult>)ViewBag.Resultats;
                    var total = resultats.Sum(r => r.total_votes);
                }
                @foreach (var r in resultats)
                {
                    var pct = total > 0
                        ? Math.Round((double)r.total_votes / total * 100, 1) : 0;
                    <div class="candidate-row mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle d-flex align-items-center
                                            justify-content-center"
                                     style="width:38px; height:38px; background:#eff6ff;
                                            min-width:38px;">
                                    <i class="fas fa-user" style="color:#3b82f6; font-size:0.9rem;"></i>
                                </div>
                                <span class="fw-semibold" style="color:#1e293b;">
                                    @r.NomCandidat @r.PrenomCandidat
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="text-muted" style="font-size:0.85rem;">
                                    @r.total_votes votes
                                </span>
                                <span class="fw-bold" style="color:#1e40af; min-width:48px;
                                             text-align:right;">
                                    @pct%
                                </span>
                            </div>
                        </div>
                        <div class="progress" style="height:10px; border-radius:999px;
                                                     background:#f1f5f9;">
                            <div class="progress-bar progress-bar-animated"
                                 style="width:@pct%; border-radius:999px;
                                        background:linear-gradient(90deg,#1e40af,#3b82f6);">
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card results-card text-center p-5">
            <i class="fas fa-inbox text-muted mb-3" style="font-size:3rem;"></i>
            <h5 class="text-muted">Aucune élection active pour le moment</h5>
            <a href="/Election/Create" class="btn btn-primary mt-3 px-4"
               style="border-radius:10px;">
                <i class="fas fa-plus me-2"></i>Créer une élection
            </a>
        </div>
    }
</div>