@model examencsharp.Models.Views.VDashboard
@using examencsharp.Controllers
@{ ViewData["Title"] = "Dashboard"; }

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }
    @@keyframes progressFill { from { width: 0% !important; } }

    .stat-card {
        border-radius: 16px !important; border: none !important;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.25s, box-shadow 0.25s;
        opacity: 0; animation: fadeInUp 0.5s ease forwards; overflow: hidden;
    }
    .stat-card:hover { transform: translateY(-5px) !important; box-shadow: 0 12px 30px rgba(0,0,0,0.1) !important; }
    .stat-card:nth-child(1) { animation-delay:0.1s; }
    .stat-card:nth-child(2) { animation-delay:0.2s; }
    .stat-card:nth-child(3) { animation-delay:0.3s; }
    .stat-card:nth-child(4) { animation-delay:0.4s; }
    .stat-value { font-size:2.2rem; font-weight:800; line-height:1; }
    .stat-icon  { width:52px; height:52px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; animation: pulse 2s ease infinite; }
    .stat-border-left { position:absolute; left:0; top:0; bottom:0; width:5px; border-radius:16px 0 0 16px; }

    .candidat-card {
        border-radius: 14px; border: 1px solid #e2e8f0;
        background: white; overflow: hidden; margin-bottom: 14px;
        transition: box-shadow 0.2s;
    }
    .candidat-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .candidat-header {
        padding: 16px 20px; display: flex; align-items: center;
        justify-content: space-between; cursor: pointer;
        background: #f8fafc; user-select: none; transition: background 0.2s;
    }
    .candidat-header:hover { background: #eff6ff; }
    .progress-bar-anim { animation: progressFill 1.2s ease forwards; }

    .votants-table thead th {
        background: #f1f5f9; font-size:0.78rem;
        text-transform: uppercase; letter-spacing: 0.6px;
        font-weight: 600; color: #64748b; padding: 10px 16px;
    }
    .votants-table tbody td { padding: 10px 16px; font-size: 0.88rem; vertical-align: middle; }
    .votants-table tbody tr:hover { background: #f8fafc; }

    .rang-badge { width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-weight:700; font-size:0.8rem; }
    .rang-1 { background:#fef9c3; color:#b45309; }
    .rang-2 { background:#e2e8f0; color:#475569; }
    .rang-3 { background:#fef3c7; color:#92400e; }
    .rang-other { background:#f1f5f9; color:#94a3b8; }
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color:#1e293b;">
                <i class="fas fa-chart-pie me-2" style="color:#3b82f6;"></i>Tableau de bord
            </h2>
            <p class="text-muted mb-0" style="font-size:0.9rem;">Vue d'ensemble du système de vote</p>
        </div>
        <span class="badge rounded-pill px-3 py-2"
              style="background:#eff6ff;color:#1e40af;font-size:0.85rem;font-weight:600;">
            <i class="fas fa-calendar me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy")
        </span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#3b82f6;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.8px;font-weight:600;">Total Citoyens</p>
                        <div class="stat-value" style="color:#1e293b;">@Model.total_citoyens</div>
                    </div>
                    <div class="stat-icon" style="background:#eff6ff;"><i class="fas fa-users" style="color:#3b82f6;"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#6366f1;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.8px;font-weight:600;">CIN Approuvées</p>
                        <div class="stat-value" style="color:#1e293b;">@Model.cin_delivered</div>
                    </div>
                    <div class="stat-icon" style="background:#eef2ff;"><i class="fas fa-id-card" style="color:#6366f1;"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#f59e0b;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.8px;font-weight:600;">En Attente</p>
                        <div class="stat-value" style="color:#f59e0b;">@Model.pending_requests</div>
                    </div>
                    <div class="stat-icon" style="background:#fffbeb;"><i class="fas fa-clock" style="color:#f59e0b;"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card position-relative p-4">
                <div class="stat-border-left" style="background:#10b981;"></div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-2" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.8px;font-weight:600;">Votes Enregistrés</p>
                        <div class="stat-value" style="color:#10b981;">@Model.total_votes</div>
                    </div>
                    <div class="stat-icon" style="background:#ecfdf5;"><i class="fas fa-vote-yea" style="color:#10b981;"></i></div>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.Resultats != null)
    {
        var resultats = (List<ResultatAvecVotants>)ViewBag.Resultats;
        int totalVotes = (int)ViewBag.TotalVotes;
        int rang = 1;

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0" style="color:#1e293b;">
                <i class="fas fa-trophy me-2" style="color:#f59e0b;"></i>Résultats — @ViewBag.ElectionTitre
            </h4>
            <span class="badge px-3 py-2" style="background:#f0fdf4;color:#166534;border-radius:999px;font-size:0.85rem;">
                <i class="fas fa-check-circle me-1"></i>@totalVotes vote(s) au total
            </span>
        </div>

        @foreach (var r in resultats)
        {
            double pct = totalVotes > 0 ? Math.Round((double)r.TotalVotes / totalVotes * 100, 1) : 0;
            string rangClass = rang == 1 ? "rang-1" : rang == 2 ? "rang-2" : rang == 3 ? "rang-3" : "rang-other";

            <div class="candidat-card">
                <div class="candidat-header" onclick="toggleVotants('v@(rang)')">
                    <div class="d-flex align-items-center gap-3">
                        <span class="rang-badge @rangClass">@rang</span>
                        <div>
                            <div class="fw-bold" style="color:#1e293b;font-size:1rem;">
                                @r.NomCandidat @r.PrenomCandidat
                            </div>
                            <small class="text-muted">@r.TotalVotes vote(s)</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:160px;">
                            <div class="d-flex justify-content-end mb-1">
                                <small class="text-muted" style="font-size:0.75rem;">@pct%</small>
                            </div>
                            <div class="progress" style="height:8px;border-radius:999px;background:#e2e8f0;">
                                <div class="progress-bar progress-bar-anim"
                                     style="width:@pct%;border-radius:999px;background:linear-gradient(90deg,#1e40af,#3b82f6);">
                                </div>
                            </div>
                        </div>
                        <span class="badge px-3 py-2" id="btn_@rang"
                              style="background:#eff6ff;color:#1e40af;border-radius:8px;font-size:0.8rem;min-width:120px;text-align:center;">
                            <i class="fas fa-users me-1"></i>Voir votants
                        </span>
                    </div>
                </div>
                <div id="v@(rang)" style="display:none;">
                    @if (r.Votants.Count > 0)
                    {
                        <table class="table votants-table mb-0">
                            <thead>
                                <tr>
                                    <th style="width:40px;">#</th>
                                    <th><i class="fas fa-user me-1"></i>Nom & Prénom</th>
                                    <th><i class="fas fa-clock me-1"></i>Date du vote</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < r.Votants.Count; i++)
                                {
                                    <tr>
                                        <td class="text-muted fw-bold">@(i+1)</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                     style="width:32px;height:32px;background:#eff6ff;min-width:32px;">
                                                    <i class="fas fa-user" style="color:#3b82f6;font-size:0.8rem;"></i>
                                                </div>
                                                <span class="fw-medium">@r.Votants[i].NomPrenom</span>
                                            </div>
                                        </td>
                                        <td class="text-muted">@r.Votants[i].DateVote.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-inbox me-2"></i>Aucun votant pour ce candidat
                        </div>
                    }
                </div>
            </div>

            rang++;
        }
    }
    else
    {
        <div class="card text-center p-5" style="border-radius:16px;border:none;box-shadow:0 2px 12px rgba(0,0,0,0.06);">
            <i class="fas fa-inbox text-muted mb-3" style="font-size:3rem;"></i>
            <h5 class="text-muted">Aucune élection active pour le moment</h5>
            <a href="/Election/Create" class="btn btn-primary mt-3 px-4" style="border-radius:10px;">
                <i class="fas fa-plus me-2"></i>Créer une élection
            </a>
        </div>
    }
</div>

@section Scripts {
<script>
function toggleVotants(id) {
    var el  = document.getElementById(id);
    var num = id.replace('v','');
    var btn = document.getElementById('btn_' + num);
    if (el.style.display === 'none') {
        el.style.display = 'block';
        btn.innerHTML = '<i class="fas fa-chevron-up me-1"></i>Masquer';
        btn.style.background = '#f0fdf4';
        btn.style.color = '#166534';
    } else {
        el.style.display = 'none';
        btn.innerHTML = '<i class="fas fa-users me-1"></i>Voir votants';
        btn.style.background = '#eff6ff';
        btn.style.color = '#1e40af';
    }
}
</script>
}