@{
    ViewData["Title"] = "Vérification 2FA";
}

<div class="container">
    <div class="row justify-content-center align-items-center vh-100">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    
                    <h3 class="mb-3">📧 Vérification</h3>
                    <p class="text-muted">Un code a été envoyé à votre email</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form method="post">
                        <div class="mb-4">
                            <input type="text" name="code"
                                   class="form-control text-center fs-4 rounded-3"
                                   placeholder="Entrez le code à 6 chiffres"
                                   maxlength="6"
                                   required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success rounded-3">
                                Vérifier
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>