@{
    ViewData["Title"] = "Accueil";
}

<style>
    .hero-section {
        background: radial-gradient(circle at top right, #1e293b, #0f172a);
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        color: white;
        padding-top: 80px;
        margin: 0;
    }

    .hero-title {
        font-weight: 800;
        font-size: calc(1.5rem + 3.5vw);
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .text-indigo { color: #6366f1; }

    .btn-hero-primary {
        background: #6366f1;
        color: white;
        border: none;
        padding: 14px 28px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-hero-outline {
        background: transparent;
        color: white;
        border: 1px solid rgba(255,255,255,0.4);
        padding: 14px 28px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-hero-primary:hover, .btn-hero-outline:hover {
        transform: translateY(-3px);
        background: #4f46e5;
        color: white;
    }

    /* Section Étapes style Portfolio */
    .step-card {
        background: white;
        border-radius: 16px;
        padding: 40px;
        border: 1px solid #e2e8f0;
        transition: 0.4s;
        height: 100%;
    }

    .step-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border-color: #6366f1;
    }

    .section-tag {
        background: rgba(99, 102, 241, 0.1);
        color: #6366f1;
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
    }
</style>

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 animate__animated animate__fadeInLeft">
                <span class="section-tag mb-3 d-inline-block">Scrutin Numérique Officiel</span>
                <h1 class="hero-title">
                    Le futur du vote <br>au <span class="text-indigo">Fokontany</span> est ici.
                </h1>
                <p class="lead mb-5 opacity-75 fs-4">
                    Une plateforme transparente, cryptée et accessible à tous les citoyens. 
                    Exprimez votre voix en toute sécurité.
                </p>
                <div class="d-flex gap-3">
                    <a href="/Account/Register" class="btn btn-hero-primary">Créer mon compte</a>
                    <a href="/Account/Login" class="btn btn-hero-outline">Connexion</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block animate__animated animate__zoomIn text-end">
                <img src="https://illustrations.popsy.co/white/abstract-art-6.svg" alt="Illustration" class="img-fluid" style="max-height: 70vh;" />
            </div>
        </div>
    </div>
</section>