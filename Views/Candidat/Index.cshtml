@model IEnumerable<examencsharp.Models.Views.VCandidate>
@{
    ViewData["Title"] = "Liste des candidats";
}


<div class="container mt-5 pt-5"> 
    
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h2 class="h4 mb-0 fw-bold text-primary">Liste des candidats</h2>
            <a class="btn btn-primary btn-sm" asp-controller="Candidat" asp-action="Create">
                + Ajouter un candidat
            </a>
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Nom</th>
                            <th>Prénom</th>
                            <th>Programme</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="ps-4">@c.NomCandidat</td>
                                    <td>@c.PrenomCandidat</td>
                                    <td><span class="badge bg-light text-dark border">@c.Programme</span></td>
                                    <td class="text-center">
                                        <span class="badge @(c.Validated ? "bg-success" : "bg-warning")">
                                            @(c.Validated ? "Validé" : "En attente")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i>Aucun candidat n'a été trouvé dans la base de données.</i>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
