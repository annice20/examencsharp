@model examencsharp.Models.Candidat

@{
    ViewData["Title"] = "Ajouter un candidat";
}

<style>
    body{
        background: linear-gradient(135deg,#4f46e5,#9333ea);
    }
    .card {
        width: 50%;
        padding: 20px;
        margin: auto;
    }
</style>

<div class="container mt-5 pt-5">
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Ajouter un candidat</h5>
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group mb-3">
                            <input asp-for="NomCandidat" class="form-control" placeholder="Nom" required />
                        </div>

                        <div class="form-group mb-3">
                            <input asp-for="PrenomCandidat" class="form-control" placeholder="Prénom" required />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Programme</label>
                            <textarea asp-for="Programme" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Election</label>
                            <select asp-for="ElectionId" class="form-control">

                                <option value="">-- Choisir une élection --</option>

                                @foreach (var e in ViewBag.Elections)
                                {
                                    <option value="@e.Id">@e.TitreElection</option>
                                }

                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Fokontany</label>

                            <select asp-for="FokontanyId" class="form-control">

                                <option value="">-- Choisir un Fokontany --</option>

                                @foreach (var f in ViewBag.Fokontany)
                                {
                                    <option value="@f.Id">@f.NomFokontany</option>
                                }

                            </select>

                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Photo du candidat</label>
                            <input type="file" name="photo" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Enregistrer
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            Annuler
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    

</div>