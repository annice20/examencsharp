@model examencsharp.Models.Citoyen
@{
    ViewData["Title"] = "Modifier Citoyen";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Modifier Citoyen</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@Model.Id" />
                        <input type="hidden" name="UtilisateurId" value="@Model.UtilisateurId" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Nom</label>
                                <input type="text" name="NomCitoyen" value="@Model.NomCitoyen"
                                       class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Prénom</label>
                                <input type="text" name="PrenomCitoyen" value="@Model.PrenomCitoyen"
                                       class="form-control" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">CIN</label>
                                <input type="text" name="CIN" value="@Model.CIN"
                                       class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Date de naissance</label>
                                <input type="date" name="DateNaissance"
                                       value="@Model.DateNaissance.ToString("yyyy-MM-dd")"
                                       class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Adresse</label>
                            <input type="text" name="Address" value="@Model.Address"
                                   class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Fokontany</label>
                            <select name="FokontanyId" class="form-select" required>
                                @foreach (var f in ViewBag.Fokontanys)
                                {
                                    if (f.Id == Model.FokontanyId)
                                    {
                                        <option value="@f.Id" selected>@f.NomFokontany</option>
                                    }
                                    else
                                    {
                                        <option value="@f.Id">@f.NomFokontany</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Mettre à jour
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>